# -----------------------------------------------------------------------------
# 논문 수집 자동화 프로그램 환경 변수 설정 템플릿
# 이 파일을 복사하여 '.env' 파일로 이름을 변경한 뒤 실제 API 키를 입력하세요.
# -----------------------------------------------------------------------------

# 해외 API 키 (선택 사항, 대량 요청 시 권장)
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# 허깅페이스 토큰 (FLUX/SDXL 등 모델 다운로드를 위해 필요할 수 있음)
HF_TOKEN=your_huggingface_token_here

# 국내 API 키 (API 연동을 원할 경우 공식 사이트에서 발급받아 입력)
# RISS: https://www.riss.kr / KERIS OpenAPI 신청 필요
RISS_API_KEY=your_riss_api_key_here

# ScienceOn: https://scienceon.kisti.re.kr / OpenAPI 신청 필요
SCIENCEON_API_KEY=your_scienceon_api_key_here

# 국회도서관: https://www.nanet.go.kr / OpenAPI 신청 필요
ASSEMBLY_LIBRARY_API_KEY=your_assembly_library_api_key_here
